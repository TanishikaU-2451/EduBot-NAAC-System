# NAAC Compliance Intelligence System Configuration
# Copy this file to .env and customize for your environment

# Application Configuration
APP_NAME="NAAC Compliance Intelligence System"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Vector Store Configuration
VECTOR_BACKEND=supabase
SUPABASE_DB_URL=
SUPABASE_TABLE=chunks
EMBEDDING_DIM=384
CHROMA_DB_PATH=./chroma_db   # fallback only if you switch VECTOR_BACKEND=chroma
JOB_STORE_URL=sqlite:///jobs.sqlite

# Groq LLM Configuration
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
GROQ_TIMEOUT=120

# Embedding Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Document Processing Configuration
DATA_DIRECTORY=./data
CACHE_DIRECTORY=./cache
UPLOADS_DIRECTORY=./uploads
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# NAAC Website Monitoring
NAAC_BASE_URL=https://www.naac.gov.in
CHECK_INTERVAL_HOURS=24
MAX_DOWNLOAD_RETRIES=3

# Retrieval Configuration
MAX_RETRIEVAL_RESULTS=10
SIMILARITY_THRESHOLD=0.7
RETRIEVAL_MODE=hybrid
RETRIEVAL_DENSE_WEIGHT=0.65
RETRIEVAL_LEXICAL_WEIGHT=0.35
RETRIEVAL_CANDIDATE_MULTIPLIER=4

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=

# Security Configuration (optional)
API_KEY=
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600